{
  "name": "love-pulsar",
  "version": "0.12.0",
  "description": "Coding tooling for making LOVE (love2d) games inside the Pulsar editor: autocomplete, hover docs, go-to-definition, and run.",
  "keywords": [
    "love2d",
    "love",
    "lua",
    "gamedev",
    "autocomplete",
    "hyperclick"
  ],
  "repository": "https://github.com/romulofer/love2d-pulsar",
  "author": "Rômulo Fernandes Evangelista",
  "license": "MIT",
  "engines": {
    "atom": ">=1.100.0 <2.0.0",
    "pulsar": ">=1.100.0"
  },
  "main": "./dist/main.js",
  "package-deps": [
    "hyperclick",
    "atom-ide-datatip",
    "linter",
    "linter-ui-default"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "providedServices": {
    "autocomplete.provider": {
      "versions": {
        "4.0.0": "provideAutocomplete"
      }
    },
    "hyperclick": {
      "versions": {
        "0.1.0": "provideHyperclick"
      }
    },
    "linter": {
      "versions": {
        "2.0.0": "provideLinter"
      }
    }
  },
  "consumedServices": {
    "datatip": {
      "versions": {
        "0.1.0": "consumeDatatipService"
      }
    },
    "status-bar": {
      "versions": {
        "^1.0.0": "consumeStatusBar"
      }
    }
  },
  "dependencies": {
    "atom-package-deps": "^8.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "typescript": "^5.5.0"
  }
}
