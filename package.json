{
  "name": "love-pulsar",
  "version": "0.11.0",
  "description": "Coding tooling for making LOVE (love2d) games inside the Pulsar editor: autocomplete, hover docs, go-to-definition, and run.",
  "keywords": [
    "love2d",
    "love",
    "lua",
    "gamedev",
    "autocomplete",
    "hyperclick"
  ],
  "repository": "https://github.com/romulo2/love-pulsar",
  "license": "MIT",
  "engines": {
    "atom": ">=1.100.0 <2.0.0",
    "pulsar": ">=1.100.0"
  },
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "providedServices": {
    "autocomplete.provider": {
      "versions": {
        "4.0.0": "provideAutocomplete"
      }
    },
    "hyperclick": {
      "versions": {
        "0.1.0": "provideHyperclick"
      }
    }
  },
  "consumedServices": {
    "datatip": {
      "versions": {
        "0.1.0": "consumeDatatipService"
      }
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "typescript": "^5.5.0"
  }
}
